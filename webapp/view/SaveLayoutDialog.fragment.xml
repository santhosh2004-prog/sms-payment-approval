<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="idSaveLayoutDialog"
        title="Save Layout"
        class="sapUiContentPadding">

        <!-- Step 1: Confirmation -->
        <VBox id="idConfirmBox">
            <Text text="Do you want to save this layout?" />
        </VBox>

        <!-- Step 2: Input (hidden initially) -->
        <VBox id="idInputBox" visible="false">
            <Label text="Layout Name" />
            <Input id="idLayoutNameInput" placeholder="Enter layout name" />
        </VBox>

        <beginButton>
            <Button
                id="idYesSaveBtn"
                text="Yes"
                press=".onConfirmSaveLayout" />
        </beginButton>

        <endButton>
            <Button
                text="No"
                press=".onSkipSaveLayout" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
