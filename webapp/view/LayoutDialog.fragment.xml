<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="layoutDialog"
        title="Select Layout"
        draggable="true"
        resizable="false"
        contentWidth="420px">

        <VBox class="sapUiSmallMargin">

            <Table
                id="layoutTable"
                items="{layoutModel>/layouts}"
                mode="SingleSelectLeft"
                includeItemInSelection="true"
                selectionChange="onLayoutSelectionChange">

                <columns>
                    <Column>
                        <Text text="Layout Name"/>
                    </Column>

                    <Column hAlign="Center">
                        <Text text="Delete"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                            <!-- Layout Name -->
                            <Text text="{layoutModel>name}"/>

                            <!-- Delete (hidden for Default row) -->
                            <Button
                                icon="sap-icon://delete"
                                type="Reject"
                                visible="{= ${layoutModel>isDefault} === false }"
                                press="onDeleteLayout"/>
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>

            <CheckBox
                id="idSetDefaultLayout"
                text="Set as default layout"
                class="sapUiSmallMarginTop"/>

        </VBox>

        <beginButton>
            <Button text="Apply" type="Accept" press="onApplyLayout"/>
        </beginButton>

        <endButton>
            <Button text="Cancel" type="Reject" press="onCloseLayoutDialog"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>
