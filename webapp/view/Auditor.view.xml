<mvc:View
    controllerName="com.incresol.zpaymentworkflow.controller.Auditor"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:table="sap.ui.table"
    xmlns:m="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%"
>
    <f:DynamicPage id="idPaymentDynamicPage">
        <!-- ================= TITLE ================= -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <m:Title text="Auditor Payment Approvals" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- ================= CONTENT ================= -->
        <f:content>
            <m:VBox
                height="100%"
                fitContainer="true"
                class="sapUiContentPadding"
            >
                <!-- ================= ACTION BAR ================= -->
                <m:Toolbar class="sapUiMediumMarginBottom customButtonToolbar">
                    <!-- Currency Display Switch -->
                    <m:Label
                        text="Show in Lakhs:"
                        class="sapUiTinyMarginEnd"
                    />
                    <m:Switch
                        id="idShowInLakhsSwitch"
                        state="{viewState>/showInLakhs}"
                        change="onSwitchShowInLakhsChange"
                        tooltip="Toggle between Rupees and Lakhs view"
                    />

                    <!-- Selection Count Display -->
                    <m:Text
                        text="{= ${viewState>/selectedCount} > 0 ? ${viewState>/selectedCount} + ' item(s) selected' : ''}"
                        visible="{viewState>/showBulkActions}"
                        class="sapUiMediumMarginBegin selectionCountBadge"
                    />

                    <m:ToolbarSpacer />

                    <!-- Button Container -->
                    <m:HBox class="buttonContainer">
                        <m:Button
                            id="idApproveButton"
                            text="Approve"
                            icon="sap-icon://accept"
                            iconFirst="true"
                            type="Success"
                            enabled="{viewState>/showBulkActions}"
                            press="onApproveButtonPress"
                            class="approveButton"
                            tooltip="Approve selected items"
                        />

                        <m:Button
                            id="idRejectButton"
                            text="Reject"
                            icon="sap-icon://cancel"
                            iconFirst="true"
                            type="Reject"
                            enabled="{viewState>/showBulkActions}"
                            press="onRejectButtonPress"
                            class="rejectButton"
                            tooltip="Reject selected items"
                        />

                        <m:Button
                            icon="sap-icon://action-settings"
                            text="Columns"
                            type="Emphasized"
                            press="onOpenColumnSettings"
                            tooltip="Choose columns"
                        />
                        <m:Button
                            icon="sap-icon://table-view"
                            text="Select Layout"
                            type="Emphasized"
                            press="onOpenLayoutDialog"
                            tooltip="Select column layout"
                        />
                    </m:HBox>
                </m:Toolbar>

                <!-- ================= TREE TABLE ================= -->
                <table:TreeTable
                    id="idTreeTable"
                    rows="{path:'treeData>/treeData', parameters:{arrayNames:['children']}}"
                    selectionMode="None"
                    enableSelectAll="false"
                    fixedColumnCount="5"
                    enableBusyIndicator="true"
                    width="100%"
                    class="sapUiSizeCompact"
                >
                    <table:Column
                        id="colRowSelection"
                        width="90px"
                        minWidth="48"
                        resizable="false"
                        hAlign="Center"
                    >
                        <table:template>
                            <m:CheckBox
                                selected="{treeData>selected}"
                                select="onSelectCheckBoxTreeTable"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Approval Note No ================= -->
                    <table:Column
                        id="idColApprovalNoteNo"
                        label="Approval Note No"
                        width="120px"
                        filterProperty="ApprovalNo"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>ApprovalNo}"
                                class="{= ${treeData>isHeader} ? 'sapThemeHighlight-asTextColor' : ''}"
                                visible="{treeData>isHeader}"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Created On (Header) ================= -->
                    <table:Column
                        id="colDate"
                        label="Date of Approval Note"
                        width="140px"
                        filterProperty="CreatedOn"
                    >
                        <table:template>
                            <m:Text
                                text="{path:'treeData>CreatedOn', type:'sap.ui.model.odata.type.DateTime', formatOptions:{pattern:'dd.MM.yyyy'}}"
                                visible="{treeData>isHeader}"
                            />
                            <m:Text
                                text="{path:'treeData>CreatedOn', type:'sap.ui.model.odata.type.DateTime', formatOptions:{pattern:'dd.MM.yyyy'}}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Profit Center (Header) ================= -->
                    <table:Column
                        id="colProfitCenter"
                        label="Profit Center"
                        width="100px"
                        filterProperty="ProfitCenter"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>ProfitCenter}"
                                visible="{treeData>isHeader}"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Profit Center Name (Header) ================= -->
                    <table:Column
                        id="colProfitCente"
                        label="Profit Center Name"
                        width="150px"
                        filterProperty="ProfitCenterName"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>ProfitCenterName}"
                                visible="{treeData>isHeader}"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Vendor Code ================= -->
                    <table:Column
                        id="colVendorCode"
                        label="Vendor Code"
                        width="120px"
                        filterProperty="VendorCode"
                    >
                        <table:template>
                            <m:Text text="{treeData>VendorCode}" />
                        </table:template>
                    </table:Column>

                    <!-- ================= Vendor Name =============
                    ==== -->
                    <table:Column
                        id="colVendorName"
                        label="Name of Vendor"
                        width="220px"
                        filterProperty="VendorName"
                    >
                        <table:template>
                            <m:Text text="{treeData>VendorName}" />
                        </table:template>
                    </table:Column>

                    <!-- ================= Liability Head (Item) ================= -->
                    <table:Column
                        id="colLiabilityHead"
                        label="Liability Head (Dropdown)"
                        width="180px"
                        filterProperty="LiabHead"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>LiabHead}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Invoice Number (Item) ================= -->
                    <table:Column
                        id="colInvoiceNo"
                        label="Invoice No."
                        width="120px"
                        filterProperty="DocNum"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>DocNum}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Purchase Order (Item) ================= -->
                    <table:Column
                        id="colPurchaseOrder"
                        label="Purchase Order"
                        width="120px"
                        filterProperty="PurchDoc"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>PurchDoc}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Document Number (Item) ================= -->
                    <table:Column
                        id="colDocumentNumber"
                        label="Document Number"
                        width="120px"
                        filterProperty="DocNum"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>DocNum}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Document Date (Item) ================= -->
                    <table:Column
                        id="colDocumentDate"
                        label="Document Date"
                        width="120px"
                        filterProperty="DocDate"
                    >
                        <table:template>
                            <m:Text
                                text="{path:'treeData>DocDate', type:'sap.ui.model.odata.type.DateTime', formatOptions:{pattern:'dd.MM.yyyy'}}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Posting Date (Item) ================= -->
                    <table:Column
                        id="colPostingDate"
                        label="Posting Date"
                        width="120px"
                        filterProperty="PostingDt"
                    >
                        <table:template>
                            <m:Text
                                text="{path:'treeData>PostingDt', type:'sap.ui.model.odata.type.DateTime', formatOptions:{pattern:'dd.MM.yyyy'}}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Gross Amount (Header + Item) ================= -->
                    <table:Column
                        id="colGrossAmt"
                        label="Gross Amount"
                        width="130px"
                        hAlign="End"
                        filterProperty="TotalBaseAmt"
                    >
                        <table:template>
                            <m:VBox>
                                <m:Text
                                    text="{parts: [{path: 'treeData>TotalBaseAmt'}, {path: 'viewState>/showInLakhs'}], formatter: '.formatter.formatCurrency'}"
                                    visible="{treeData>isHeader}"
                                    class="sapThemeHighlight-asTextColor"
                                />
                                <m:Text
                                    text="{parts: [{path: 'treeData>BaseAmt'}, {path: 'viewState>/showInLakhs'}], formatter: '.formatter.formatCurrency'}"
                                    visible="{= !${treeData>isHeader} }"
                                />
                            </m:VBox>
                        </table:template>
                    </table:Column>

                    <!-- ================= GST Amount (Header + Item) ================= -->
                    <table:Column
                        id="colGST"
                        label="GST Amount"
                        width="130px"
                        hAlign="End"
                        filterProperty="TotalGstAmt"
                    >
                        <table:template>
                            <m:VBox>
                                <m:Text
                                    text="{parts: [{path: 'treeData>TotalGstAmt'}, {path: 'viewState>/showInLakhs'}], formatter: '.formatter.formatCurrency'}"
                                    visible="{treeData>isHeader}"
                                    class="sapThemeHighlight-asTextColor"
                                />
                                <m:Text
                                    text="{parts: [{path: 'treeData>GstAmt'}, {path: 'viewState>/showInLakhs'}], formatter: '.formatter.formatCurrency'}"
                                    visible="{= !${treeData>isHeader} }"
                                />
                            </m:VBox>
                        </table:template>
                    </table:Column>

                    <!-- ================= TDS Amount (Header + Item) ================= -->
                    <table:Column
                        id="colTDS"
                        label="TDS Amount"
                        width="200px"
                        hAlign="End"
                        filterProperty="TotalTdsAmount"
                    >
                        <table:template>
                            <m:VBox>
                                <m:Text
                                    text="{parts: [{path: 'treeData>TotalTdsAmount'}, {path: 'viewState>/showInLakhs'}], formatter: '.formatter.formatCurrency'}"
                                    visible="{treeData>isHeader}"
                                    class="sapThemeHighlight-asTextColor"
                                />
                                <m:Input
                                    value="{treeData>TdsAmount}"
                                    visible="{= !${treeData>isHeader} }"
                                    type="Number"
                                    width="100%"
                                    placeholder="0.00"
                                    textAlign="End"
                                    change="onTdsAmountChange"
                                />
                            </m:VBox>
                        </table:template>
                    </table:Column>

                    <!-- ================= Total Liability (Header + Item) ================= -->
                    <table:Column
                        id="colTotalLiability"
                        label="Total Liability"
                        width="130px"
                        hAlign="End"
                        filterProperty="TotalLiability"
                    >
                        <table:template>
                            <m:Text
                                text="{parts: [{path: 'treeData>TotalLiability'}, {path: 'viewState>/showInLakhs'}], formatter: '.formatter.formatCurrency'}"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Amount Claimed (Header + Item) ================= -->
                    <table:Column
                        id="colAmtClaimed"
                        label="Amount Claimed"
                        width="130px"
                        hAlign="End"
                        filterProperty="TotalAmtClaimed"
                    >
                        <table:template>
                            <m:VBox>
                                <m:Text
                                    text="{parts: [{path: 'treeData>TotalAmtClaimed'}, {path: 'viewState>/showInLakhs'}], formatter: '.formatter.formatCurrency'}"
                                    visible="{treeData>isHeader}"
                                    class="sapThemeHighlight-asTextColor"
                                />
                                <m:Text
                                    text="{parts: [{path: 'treeData>AmtClaimed'}, {path: 'viewState>/showInLakhs'}], formatter: '.formatter.formatCurrency'}"
                                    visible="{= !${treeData>isHeader} }"
                                />
                            </m:VBox>
                        </table:template>
                    </table:Column>

                    <!-- ================= GST Amount reflected in GSTR 2A ================= -->
                    <table:Column
                        id="colGst2aRef"
                        label="GST Amount reflected in GSTR 2A"
                        width="150px"
                        hAlign="End"
                        filterProperty="Gst2aRef"
                    >
                        <table:template>
                            <m:Text
                                text="{parts: [{path: 'treeData>Gst2aRef'}, {path: 'viewState>/showInLakhs'}], formatter: '.formatter.formatCurrency'}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= GST Amount not reflected in GSTR 2A ================= -->
                    <table:Column
                        id="colGst2aNref"
                        label="GST Amount not reflected in GSTR 2A"
                        width="150px"
                        hAlign="End"
                        filterProperty="Gst2aNref"
                    >
                        <table:template>
                            <m:Text
                                text="{parts: [{path: 'treeData>Gst2aNref'}, {path: 'viewState>/showInLakhs'}], formatter: '.formatter.formatCurrency'}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Amount already claimed in approval notes ================= -->
                    <table:Column
                        id="colAmtAlreadyClaimed"
                        label="Amount already claimed in approval notes"
                        width="180px"
                        hAlign="End"
                        filterProperty="AmtClaimed"
                    >
                        <table:template>
                            <m:Text
                                text="{parts: [{path: 'treeData>AmtClaimed'}, {path: 'viewState>/showInLakhs'}], formatter: '.formatter.formatCurrency'}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Approval notes Pr. Ref ================= -->
                    <table:Column
                        id="colAprnoRef"
                        label="Approval notes Pr. Ref"
                        width="150px"
                        filterProperty="AprnoRef"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>AprnoRef}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Amount proposed to be paid ================= -->
                    <table:Column
                        id="colAmtProposed"
                        label="Amount proposed to be paid"
                        width="150px"
                        hAlign="End"
                        filterProperty="ProposedAmt"
                    >
                        <table:template>
                            <m:Text
                                text="{parts: [{path: 'treeData>ProposedAmt'}, {path: 'viewState>/showInLakhs'}], formatter: '.formatter.formatCurrency'}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Amount approved by Project Manager ================= -->
                    <table:Column
                        id="colPmApprAmt"
                        label="Amount approved by Project Manager"
                        width="200px"
                        hAlign="End"
                        filterProperty="PmApprAmt"
                    >
                        <!-- <m:Input
                                value="{treeData>PmApprAmt}"
                                visible="{= !${treeData>isHeader} }"
                                type="Number"
                                placeholder="0.00"
                                textAlign="End"
                                change="onPmApprAmountChange"
                            /> -->
                        <table:template>
                            <m:Text
                                text="{treeData>PmApprAmt}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>
                    <table:Column
                        id="colCfoApprAmt"
                        label="Amount approved by CFO"
                        width="200px"
                        hAlign="End"
                        filterProperty="CfoApprAmt"
                    >
                        <!-- <m:Input
                                value="{treeData>PmApprAmt}"
                                visible="{= !${treeData>isHeader} }"
                                type="Number"
                                placeholder="0.00"
                                textAlign="End"
                                change="onPmApprAmountChange"
                            /> -->
                        <table:template>
                            <m:Text
                                text="{treeData>CfoApprAmt}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <table:Column
                        id="colAuditorApprAmt"
                        label="Amount approved by auditor"
                        width="200px"
                        hAlign="End"
                        filterProperty="AudApprAmt"
                    >
                        <table:template>
                            <m:Input
                                value="{treeData>AudApprAmt}"
                                visible="{= !${treeData>isHeader} }"
                                type="Number"
                                placeholder="0.00"
                                textAlign="End"
                                change="onPmApprAmountChange"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= PM Status (Header=OverallStatus, Item=PmApprStatus) ================= -->
                    <!-- <table:Column
                        id="colPmStatus"
                        label="PM Status"
                        width="120px"
                        filterProperty="PmApprStatus"
                    >
                        <table:template>
                            <m:ObjectStatus
                                text="{= ${treeData>isHeader} ? ${treeData>OverallStatus} : ${treeData>PmApprStatus} }"
                                state="{path:'treeData>OverallStatus', formatter:'.formatter.statusState'}"
                            />
                        </table:template>
                    </table:Column> -->

                    <table:Column
                        id="colPmRemark"
                        label="pm   Remark"
                        width="200px"
                        filterProperty="PmApprRemarks"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>PmApprRemarks}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>
                    <table:Column
                        id="colCfoRemark"
                        label="cfo   Remark"
                        width="200px"
                        filterProperty="CfoApprRemarks"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>CfoApprRemarks}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= PM Remark (Item) ================= -->
                    <table:Column
                        id="colAuditorRemark"
                        label="auditor  Remark"
                        width="200px"
                        filterProperty="AudApprRemarks"
                    >
                        <table:template>
                            <m:Input
                                value="{treeData>AudApprRemarks}"
                                visible="{= !${treeData>isHeader} }"
                                placeholder="Enter remarks..."
                                maxLength="255"
                                change="onRemarksChange"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Bank Name (Item) ================= -->
                    <table:Column
                        id="colBankName"
                        label="Bank Name"
                        width="200px"
                        filterProperty="BankName"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>BankName}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Account Number (Item) ================= -->
                    <table:Column
                        id="colAccountNumber"
                        label="Account Number"
                        width="160px"
                        filterProperty="AccountNumber"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>AccountNumber}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Currency (Header + Item) ================= -->
                    <table:Column
                        id="colCurrency"
                        label="Currency"
                        width="80px"
                        filterProperty="Currency"
                    >
                        <table:template>
                            <m:Text text="{treeData>Currency}" />
                        </table:template>
                    </table:Column>

                    <!-- ================= Company Code (Header) ================= -->
                    <table:Column
                        id="colCompanyCode"
                        label="Company Code"
                        width="120px"
                        filterProperty="CompanyCode"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>CompanyCode}"
                                visible="{treeData>isHeader}"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Created By (Header) ================= -->
                    <table:Column
                        id="colCreatedBy"
                        label="Created By"
                        width="120px"
                        filterProperty="CreatedBy"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>CreatedBy}"
                                visible="{treeData>isHeader}"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Creation Time (Header) ================= -->
                    <table:Column
                        id="colCreationTime"
                        label="Creation Time"
                        width="140px"
                        filterProperty="CreatedAt"
                    >
                        <table:template>
                            <m:Text
                                text="{path:'treeData>CreatedAt', type:'sap.ui.model.odata.type.DateTime', formatOptions:{pattern:'dd.MM.yyyy HH:mm:ss'}}"
                                visible="{treeData>isHeader}"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Item Count (Header) ================= -->
                    <table:Column
                        id="colItemCount"
                        label="Item Count"
                        width="100px"
                        filterProperty="ItemCount"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>ItemCount}"
                                visible="{treeData>isHeader}"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Tax Number (Item) ================= -->
                    <table:Column
                        id="colTaxNumber"
                        label="Tax Number"
                        width="120px"
                        filterProperty="TaxNum"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>TaxNum}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Bank Key (Item) ================= -->
                    <table:Column
                        id="colBankKey"
                        label="Bank Key"
                        width="100px"
                        filterProperty="BankKey"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>BankKey}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Reference Document (Item) ================= -->
                    <table:Column
                        id="colReferenceDocument"
                        label="Reference Document"
                        width="150px"
                        filterProperty="ReferenceDoc"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>ReferenceDoc}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= GSTR1 Details (Item) ================= -->
                    <table:Column
                        id="colGstr1Details"
                        label="GSTR1 Details"
                        width="150px"
                        filterProperty="Gstr1Details"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>Gstr1Details}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= General Remark (Item) ================= -->
                    <table:Column
                        id="colGeneralRemark"
                        label="General Remark"
                        width="200px"
                        filterProperty="Remark"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>Remark}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Account Holder (Item) ================= -->
                    <table:Column
                        id="colAccountHolder"
                        label="Account Holder"
                        width="180px"
                        filterProperty="AccountHolder"
                    >
                        <table:template>
                            <m:Text
                                text="{treeData>AccountHolder}"
                                visible="{= !${treeData>isHeader} }"
                            />
                        </table:template>
                    </table:Column>

                    <!-- ================= Branch (Item) ================= -->
                </table:TreeTable>
            </m:VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>
